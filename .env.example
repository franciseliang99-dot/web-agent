# LLM provider 选择 (anthropic / openai)。不设则按 model 名前缀推断 (claude-* / gpt-* / o[1-5]-*)
# WEB_AGENT_LLM_PROVIDER=anthropic

# === Anthropic（默认 provider）===
ANTHROPIC_API_KEY=
# 可选：透传给 SDK base_url，支持 OpenRouter Anthropic skin / 自部署 LiteLLM 代理
# ANTHROPIC_BASE_URL=https://openrouter.ai/api

# === OpenAI（可选, 安装时 uv sync --extra openai）===
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# === Kimi / Moonshot（OpenAI compat，走 openai SDK）===
# 国际版 (platform.kimi.ai key):
#   OPENAI_API_KEY=sk-xxx
#   OPENAI_BASE_URL=https://api.moonshot.ai/v1
#   WEB_AGENT_MODEL=kimi-k2.6        # 自动推断 provider=openai
# 国内版 (platform.moonshot.cn key):
#   OPENAI_BASE_URL=https://api.moonshot.cn/v1

# === 通用覆盖 ===
WEB_AGENT_MODEL=claude-sonnet-4-6
WEB_AGENT_CDP_URL=http://127.0.0.1:9222
WEB_AGENT_MAX_STEPS=20
WEB_AGENT_MAX_WALLCLOCK_S=300
WEB_AGENT_VIEWPORT_WIDTH=1280
WEB_AGENT_VIEWPORT_HEIGHT=800

# 自动关 cookie/GDPR/notification 弹窗 (只关含 cookie/consent/gdpr 关键词的容器, OAuth/付款 modal 黑名单跳过)
# WEB_AGENT_AUTO_DISMISS=true

# Safety 白名单预授权 (CSV)：默认拦 send/pay/delete/转账/支付/密码字段/OTP 等敏感 action
# 例: WEB_AGENT_AUTO_APPROVE=send-or-pay   # 单 rule
# 例: WEB_AGENT_AUTO_APPROVE=send-or-pay,zh-send-or-pay,input-type-sensitive   # 多 rule
# 例: WEB_AGENT_AUTO_APPROVE=*    # 全开 (生产慎用)
# 规则名见 src/web_agent/safety.py
# WEB_AGENT_AUTO_APPROVE=

# === Captcha 接管 UX (W4-2) ===
# 命中 Cloudflare Turnstile / reCAPTCHA / hCaptcha / "verify you're not a robot"
# 时暂停 loop, 用户在浏览器手解, 自动恢复; 超时 graceful abort 写 trace。
# 完全关闭 (退化到 V0.8.x 不检测 captcha):
# WEB_AGENT_CAPTCHA_DISABLE=true
WEB_AGENT_CAPTCHA_TIMEOUT_S=300
WEB_AGENT_CAPTCHA_POLL_S=3

# === Perception (W5-B Shadow DOM 穿透) ===
# SoM 默认走 open shadowRoot 穿透, 标到 React Web Components / Stripe / 部分 GitHub UI。
# 出问题退化到 V0.11.x light-DOM only:
# WEB_AGENT_SOM_SHADOW=false

# === Notify (W4-3 desktop notification) ===
# captcha 命中/超时桌面通知 (macOS osascript / Linux notify-send),
# tmux/SSH 离开终端也能感知。CI / headless / 不想被打扰场景关掉:
# WEB_AGENT_NOTIFY_DISABLE=true

# === Demo 专用 ===
# gmail_compose (W3-C) 收件人, 强烈建议自己发给自己, 不要拿别人邮箱当测试目标
# WEB_AGENT_TEST_RECIPIENT=youremail@example.com
